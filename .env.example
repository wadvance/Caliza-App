# ============================================================
# GeoCaliza - Variables de entorno
# ============================================================
# Copiar a .env y llenar los valores

# --- Firebase (producción) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- Backend API URL (para la app mobile) ---
EXPO_PUBLIC_API_URL=http://localhost:8000

# --- Backend (FastAPI) ---
SECRET_KEY=geocaliza-dev-secret-change-in-production
DEBUG=true

# --- Firebase Admin SDK (solo backend) ---
GOOGLE_APPLICATION_CREDENTIALS=firebase-service-account.json
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_URL=

# --- Base de datos (ya no aplica, ahora usamos Firestore) ---
# DB_PASSWORD ya no es necesaria
